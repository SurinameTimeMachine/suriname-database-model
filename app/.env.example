# GitHub OAuth App credentials (for place editing)
# Create at: https://github.com/settings/developers -> OAuth Apps -> New
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# Repository to commit gazetteer changes to
GITHUB_REPO_OWNER=SurinameTimeMachine
GITHUB_REPO_NAME=suriname-database-model
GITHUB_REPO_BRANCH=main

# Public base URL (used for OAuth callback)
NEXT_PUBLIC_BASE_URL=http://localhost:3000
